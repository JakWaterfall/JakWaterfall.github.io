---
import "../styles/global.css";

const { title = "Jak Waterfall - Software Engineer" } = Astro.props;
---

<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="color-scheme" content="dark" />
    <meta name="theme-color" content="#0c0e12" />
    <title>{title}</title>
    <meta
        name="description"
        content="CV and portfolio for software engineer Jak Waterfall."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
        href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&family=JetBrains+Mono:wght@400;500&display=swap"
        rel="stylesheet"
    />
</head>

<body>
    <slot />
</body>
</html>